<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_background"
        android:padding="16dp"
        android:orientation="vertical">

        <!-- File Name Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/cilfilename"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="2"
                android:hint="@string/edit_hint_input_file_name"
                android:background="@drawable/input_field_background"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textSize="14sp"
                android:singleLine="true"
                android:layout_marginRight="8dp"/>

            <Spinner
                android:id="@+id/cilnametype"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/input_field_background"/>
        </LinearLayout>

        <!-- File Size Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/cilsize"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="2"
                android:inputType="number"
                android:hint="@string/edit_hint_input_file_size"
                android:background="@drawable/input_field_background"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textSize="14sp"
                android:singleLine="true"
                android:layout_marginRight="8dp"/>

            <Spinner
                android:id="@+id/cilsizetype"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/input_field_background"/>
        </LinearLayout>

        <Button
            android:id="@+id/cilcreateimg"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/button_start_create"
            android:textColor="@color/onPrimary"
            android:background="@drawable/btn_material"/>

    </LinearLayout>

</LinearLayout>