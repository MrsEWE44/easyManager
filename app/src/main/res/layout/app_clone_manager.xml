<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_background"
        android:padding="12dp"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/acmet1"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="number"
            android:hint="@string/app_clone_input_size_hint_str"
            android:background="@drawable/input_field_background"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Spinner
                android:id="@+id/acmsp1"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/input_field_background"
                android:layout_marginRight="4dp"/>

            <Spinner
                android:id="@+id/acmsp2"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/input_field_background"
                android:layout_marginLeft="4dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/clmbt1"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/app_clone_button_default_str"
            android:textColor="@color/onPrimary"
            android:background="@drawable/btn_material"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <ListView
            android:id="@+id/acmlv1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/card_background"
            android:divider="@color/divider"
            android:dividerHeight="1dp"
            android:layout_marginRight="4dp"
            android:padding="4dp"/>

        <ListView
            android:id="@+id/acmlv2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/card_background"
            android:divider="@color/divider"
            android:dividerHeight="1dp"
            android:layout_marginLeft="4dp"
            android:padding="4dp"/>

    </LinearLayout>

</LinearLayout>