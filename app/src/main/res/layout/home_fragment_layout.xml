<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- App Management Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:background="@drawable/card_background"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/manager_grant_app_foreground" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12dp"
                        android:text="@string/text_home_app_manage"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/onSurface" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button
                        android:id="@+id/hflappmanagerbt"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_marginRight="4dp"
                        android:text="@string/text_home_app_manage"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                    <Button
                        android:id="@+id/hflinlocalapk"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_marginLeft="4dp"
                        android:text="@string/button_home_install_local_file"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                </LinearLayout>
            </LinearLayout>

            <!-- Backup Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:background="@drawable/card_background"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/backup_foreground" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12dp"
                        android:text="@string/text_home_backup_and_restory_manage"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/onSurface" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button
                        android:id="@+id/hflbackupapp"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_marginRight="4dp"
                        android:text="@string/button_home_backup"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                    <Button
                        android:id="@+id/hflrestoryapp"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_marginLeft="4dp"
                        android:text="@string/button_home_restory"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                </LinearLayout>
            </LinearLayout>

            <!-- App Clone Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:background="@drawable/card_background"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/appclone_foreground" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12dp"
                        android:text="@string/app_clone_menu"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/onSurface" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button
                        android:id="@+id/hflappclone"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_marginRight="2dp"
                        android:text="@string/app_clone_button"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                    <Button
                        android:id="@+id/hflappclonemanage"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="2dp"
                        android:text="@string/app_clone_manager_button"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                    <Button
                        android:id="@+id/hflappcloneremove"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_marginLeft="2dp"
                        android:text="@string/app_clone_delete_button"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                </LinearLayout>
            </LinearLayout>

            <!-- USB Mode Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:background="@drawable/card_background"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/usbmode_foreground" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12dp"
                        android:text="@string/text_home_usb_flash_drive_mode"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/onSurface" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button
                        android:id="@+id/hflmountlocalimg"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_marginRight="4dp"
                        android:text="@string/button_home_use_usb_mode"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                    <Button
                        android:id="@+id/hflcreateimg"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:layout_marginLeft="4dp"
                        android:text="@string/button_home_create_usb_img_file"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                </LinearLayout>
            </LinearLayout>

            <!-- Other Tools Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:background="@drawable/card_background"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/othertool_foreground" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12dp"
                        android:text="@string/text_home_other_tool"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/onSurface" />
                </LinearLayout>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2">
                    <Button
                        android:id="@+id/hflsetntp"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        android:text="@string/button_home_set_ntp"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                    <Button
                        android:id="@+id/hflsetrate"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        android:text="@string/button_home_set_rate"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                    <Button
                        android:id="@+id/hfldelx"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        android:text="@string/button_home_del_x"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                    <Button
                        android:id="@+id/hflfileshared"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        android:text="@string/button_home_file_share"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                    <Button
                        android:id="@+id/hflruncmd"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_height="48dp"
                        android:layout_margin="4dp"
                        android:text="@string/button_home_run_cmd"
                        android:textColor="@color/onPrimary"
                        android:background="@drawable/btn_material" />
                </GridLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>